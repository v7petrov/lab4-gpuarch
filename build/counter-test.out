#! /usr/bin/vvp
:ivl_version "11.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2009.vpi";
S_0x62857aa98df0 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x62857aa98f80 .scope module, "tb_counter" "tb_counter" 3 1;
 .timescale 0 0;
v0x62857aae3c80_0 .var "clk", 0 0;
v0x62857aae3d50_0 .net "count", 3 0, v0x62857aa9aba0_0;  1 drivers
v0x62857aae3e20_0 .var "rst", 0 0;
S_0x62857aad33f0 .scope module, "dut" "counter" 3 8, 4 1 0, S_0x62857aa98f80;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "rst";
    .port_info 2 /OUTPUT 4 "count";
v0x62857aa9a7b0_0 .net "clk", 0 0, v0x62857aae3c80_0;  1 drivers
v0x62857aa9aba0_0 .var "count", 3 0;
v0x62857aae3b60_0 .net "rst", 0 0, v0x62857aae3e20_0;  1 drivers
E_0x62857aad3b20 .event posedge, v0x62857aa9a7b0_0;
    .scope S_0x62857aad33f0;
T_0 ;
    %wait E_0x62857aad3b20;
    %load/vec4 v0x62857aae3b60_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %pushi/vec4 0, 0, 4;
    %assign/vec4 v0x62857aa9aba0_0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0x62857aa9aba0_0;
    %addi 1, 0, 4;
    %assign/vec4 v0x62857aa9aba0_0, 0;
T_0.1 ;
    %jmp T_0;
    .thread T_0;
    .scope S_0x62857aa98f80;
T_1 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x62857aae3c80_0, 0, 1;
    %end;
    .thread T_1;
    .scope S_0x62857aa98f80;
T_2 ;
    %delay 5, 0;
    %load/vec4 v0x62857aae3c80_0;
    %inv;
    %store/vec4 v0x62857aae3c80_0, 0, 1;
    %jmp T_2;
    .thread T_2;
    .scope S_0x62857aa98f80;
T_3 ;
    %vpi_call/w 3 20 "$dumpfile", "wave.vcd" {0 0 0};
    %vpi_call/w 3 21 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x62857aa98f80 {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x62857aae3e20_0, 0, 1;
    %delay 20, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x62857aae3e20_0, 0, 1;
    %delay 100, 0;
    %vpi_call/w 3 28 "$finish" {0 0 0};
    %end;
    .thread T_3;
